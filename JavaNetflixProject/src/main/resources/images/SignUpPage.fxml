<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.JavaProject.JavaNetflixProject.app.SignUpController"
           styleClass="auth-root"
           stylesheets="@/css/auth-theme.css"
           prefWidth="1100" prefHeight="780">

    <!-- Background -->
    <Region maxWidth="Infinity" maxHeight="Infinity"
            style="-fx-background-color: linear-gradient(to bottom right, #080810 0%, #0c0c18 50%, #080810 100%);"/>
    <Region prefWidth="700" prefHeight="700"
            style="-fx-background-color: radial-gradient(center 75% 25%, radius 50%, rgba(60,40,140,0.07) 0%, transparent 70%);"/>
    <Region prefWidth="700" prefHeight="700"
            style="-fx-background-color: radial-gradient(center 30% 80%, radius 40%, rgba(232,0,15,0.05) 0%, transparent 70%);"/>

    <HBox alignment="CENTER" spacing="0" maxHeight="Infinity" maxWidth="Infinity">

        <!-- LEFT: Branding -->
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="24" style="-fx-padding:0 60 0 80;">
            <HBox alignment="CENTER_LEFT" spacing="0">
                <Label text="NOT" styleClass="brand-not"/>
                <Label text="FLIX" styleClass="brand-flix"/>
            </HBox>
            <Label text="JOIN THE STREAM" styleClass="brand-tagline"/>
            <Pane prefHeight="10"/>
            <VBox spacing="14">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="▶" style="-fx-text-fill:#e8000f;-fx-font-size:14px;"/>
                    <Label text="Thousands of films &amp; series" style="-fx-text-fill:#1c1c30;-fx-font-size:15px;"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="▶" style="-fx-text-fill:#e8000f;-fx-font-size:14px;"/>
                    <Label text="Continue watching across devices" style="-fx-text-fill:#171728;-fx-font-size:15px;"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="▶" style="-fx-text-fill:#e8000f;-fx-font-size:14px;"/>
                    <Label text="Build your personal watchlist" style="-fx-text-fill:#141422;-fx-font-size:15px;"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- RIGHT: Sign up Card -->
        <VBox alignment="CENTER" style="-fx-padding:0 60 0 0;" prefWidth="520" maxWidth="520">
            <ScrollPane fitToWidth="true" styleClass="scroll-pane"
                        style="-fx-background-color:transparent;" prefHeight="680" maxHeight="680">
            <VBox styleClass="auth-card" spacing="0">

                <!-- Header -->
                <VBox spacing="6" style="-fx-padding:0 0 24 0;">
                    <Label text="Create your account" styleClass="auth-title"/>
                    <Label text="Start watching in seconds" styleClass="auth-subtitle"/>
                </VBox>

                <!-- Name -->
                <VBox spacing="6" style="-fx-padding:0 0 14 0;">
                    <Label text="DISPLAY NAME" styleClass="field-label"/>
                    <TextField fx:id="username" styleClass="auth-field"
                               promptText="e.g. Michael Scott" maxWidth="Infinity"/>
                </VBox>

                <!-- Email -->
                <VBox spacing="6" style="-fx-padding:0 0 14 0;">
                    <Label text="EMAIL ADDRESS" styleClass="field-label"/>
                    <TextField fx:id="email" styleClass="auth-field"
                               promptText="your@email.com" maxWidth="Infinity"/>
                </VBox>

                <!-- Password -->
                <VBox spacing="6" style="-fx-padding:0 0 6 0;">
                    <Label text="PASSWORD" styleClass="field-label"/>
                    <PasswordField fx:id="password" styleClass="auth-pass"
                                   promptText="Min 8 chars, 1 number, 1 symbol"
                                   onKeyReleased="#onPasswordTyped" maxWidth="Infinity"/>
                </VBox>

                <!-- Strength bar -->
                <VBox spacing="5" style="-fx-padding:0 0 14 0;">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <StackPane HBox.hgrow="ALWAYS" styleClass="strength-bar-bg" alignment="CENTER_LEFT">
                            <Pane fx:id="strengthFill" styleClass="strength-fill-weak"
                                  prefHeight="4" prefWidth="0"/>
                        </StackPane>
                        <Label fx:id="strengthLabel" text="Too weak"
                               styleClass="strength-label" style="-fx-text-fill:#ff3b3b;-fx-min-width:62px;"/>
                    </HBox>
                    <Label fx:id="passwordHint" text="Use 8+ characters with numbers and symbols."
                           style="-fx-text-fill:#333344;-fx-font-size:10px;"/>
                </VBox>

                <!-- Confirm Password -->
                <VBox spacing="6" style="-fx-padding:0 0 20 0;">
                    <Label text="CONFIRM PASSWORD" styleClass="field-label"/>
                    <PasswordField fx:id="confirmpassword" styleClass="auth-pass"
                                   promptText="••••••••" maxWidth="Infinity"/>
                </VBox>

                <!-- Divider -->
                <Pane styleClass="auth-divider" style="-fx-margin: 0 0 18 0;"/>
                <Pane prefHeight="14"/>

                <!-- Admin Account Toggle -->
                <VBox fx:id="adminToggle" styleClass="admin-toggle-area" spacing="2"
                      style="-fx-padding:0 0 16 0; -fx-cursor:hand;"
                      onMouseClicked="#toggleAdminSection">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="🔐" style="-fx-font-size:16px;"/>
                        <VBox spacing="1" HBox.hgrow="ALWAYS">
                            <Label text="Create Admin Account" styleClass="admin-toggle-label"/>
                            <Label text="Requires authorization code — click to expand" styleClass="admin-toggle-sub"/>
                        </VBox>
                        <Label fx:id="adminArrow" text="▶" style="-fx-text-fill:#553333;-fx-font-size:11px;"/>
                    </HBox>
                </VBox>

                <!-- Admin fields (hidden by default) -->
                <VBox fx:id="adminFields" styleClass="admin-fields" spacing="10"
                      visible="false" managed="false" style="-fx-padding:0 0 18 0;">
                    <Label text="ADMIN CODE" styleClass="field-label" style="-fx-text-fill:#883333;"/>
                    <PasswordField fx:id="adminCode" styleClass="auth-pass"
                                   promptText="Enter authorization code" maxWidth="Infinity"/>
                    <Label text="ℹ  The admin code is provided by your organization."
                           style="-fx-text-fill:#443333;-fx-font-size:10px;"/>
                </VBox>

                <!-- Error label -->
                <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"
                       style="-fx-padding:0 0 12 0;" visible="false" managed="false"/>

                <!-- Register button -->
                <Button text="Create Account →" styleClass="btn-auth-primary"
                        onAction="#onRegister" maxWidth="Infinity"/>

                <!-- Divider -->
                <HBox alignment="CENTER" spacing="12" style="-fx-padding:20 0 20 0;">
                    <Pane styleClass="auth-divider" HBox.hgrow="ALWAYS"/>
                    <Label text="OR" style="-fx-text-fill:#222233;-fx-font-size:10px;-fx-font-weight:700;-fx-letter-spacing:0.2em;"/>
                    <Pane styleClass="auth-divider" HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Login link -->
                <HBox alignment="CENTER" spacing="6">
                    <Label text="Already have an account?" styleClass="auth-link" style="-fx-cursor:default;"/>
                    <Hyperlink fx:id="goToLogin" text="Sign in" styleClass="auth-link-highlight"
                               onAction="#goToLogin"/>
                </HBox>

            </VBox>
            </ScrollPane>
        </VBox>

    </HBox>
</StackPane>
