<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.JavaProject.JavaNetflixProject.app.MyListController"
            styleClass="mylist-root"
            stylesheets="@/css/auth-theme.css"
            prefWidth="1280" prefHeight="800">

    <!-- ═══ NAVBAR ═══ -->
    <top>
        <HBox styleClass="mylist-navbar" alignment="CENTER_LEFT" spacing="18">
            <!-- Brand -->
            <HBox alignment="CENTER_LEFT" spacing="0">
                <Label text="NOT" styleClass="mylist-brand-not"/>
                <Label text="FLIX" styleClass="mylist-brand-flix"/>
            </HBox>
            <Label text="|" styleClass="mylist-nav-sep"/>
            <Label text="My List" styleClass="mylist-nav-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="usernameLabel" text="" styleClass="mylist-username"/>
            <Button text="← Home" onAction="#onBack" styleClass="btn-back"/>
        </HBox>
    </top>

    <!-- ═══ CONTENT ═══ -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="0" style="-fx-background-color:#080810;">
                <padding><Insets top="36" bottom="40" left="48" right="48"/></padding>

                <!-- ══ CONTINUE WATCHING ══ -->
                <VBox spacing="18" style="-fx-padding:0 0 40 0;">
                    <HBox alignment="CENTER_LEFT" spacing="14">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="CONTINUE WATCHING" styleClass="mylist-section-sub"/>
                            <Label text="Pick up where you left off" styleClass="mylist-section-title"/>
                        </VBox>
                        <Label fx:id="cwCountLabel" text="0 items" styleClass="mylist-count"/>
                    </HBox>

                    <!-- Continue watching cards row (horizontal scroll) -->
                    <ScrollPane fitToHeight="true"
                                style="-fx-background-color:transparent;-fx-background:transparent;-fx-border-color:transparent;-fx-hbar-policy:as-needed;-fx-vbar-policy:never;"
                                prefHeight="280">
                        <HBox fx:id="cwGrid" spacing="16" alignment="CENTER_LEFT">
                            <padding><Insets top="4" bottom="12" left="2" right="2"/></padding>
                        </HBox>
                    </ScrollPane>

                    <!-- Empty state for continue watching -->
                    <VBox fx:id="cwEmpty" alignment="CENTER" spacing="10"
                          style="-fx-padding:30 0 10 0;" visible="false" managed="false">
                        <Label text="▶" styleClass="empty-state-icon" style="-fx-text-fill:#1a1a2e;"/>
                        <Label text="Nothing in progress" styleClass="empty-state-title" style="-fx-text-fill:#1c1c30;"/>
                        <Label text="Start watching something to see it here." styleClass="empty-state-sub"/>
                    </VBox>
                </VBox>

                <!-- Divider -->
                <Pane style="-fx-background-color:rgba(255,255,255,0.05);-fx-pref-height:1px;-fx-min-height:1px;-fx-max-height:1px;"
                      style="-fx-margin: 0 0 36 0;"/>
                <Pane prefHeight="36"/>

                <!-- ══ MY WATCHLIST ══ -->
                <VBox spacing="18">
                    <HBox alignment="CENTER_LEFT" spacing="14">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="SAVED FOR LATER" styleClass="mylist-section-sub"/>
                            <Label text="My Watchlist" styleClass="mylist-section-title"/>
                        </VBox>
                        <Label fx:id="wlCountLabel" text="0 saved" styleClass="mylist-count"/>
                    </HBox>

                    <FlowPane fx:id="watchlistGrid" hgap="16" vgap="18"/>

                    <!-- Empty state for watchlist -->
                    <VBox fx:id="wlEmpty" alignment="CENTER" spacing="10"
                          style="-fx-padding:30 0 10 0;" visible="false" managed="false">
                        <Label text="🎬" styleClass="empty-state-icon" style="-fx-text-fill:#1a1a2e;"/>
                        <Label text="Your watchlist is empty" styleClass="empty-state-title" style="-fx-text-fill:#1c1c30;"/>
                        <Label text="Browse films and series and add them to your list." styleClass="empty-state-sub"/>
                    </VBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
