<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.JavaProject.JavaNetflixProject.app.HomeController"
           stylesheets="@/css/dark-theme.css"
           styleClass="root-pane"
           minWidth="960" minHeight="540">

    <!-- ══════════════════ MAIN UI ══════════════════ -->
    <BorderPane>

        <!-- ── TOP BAR ────────────────────────────── -->
        <top>
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="top-bar">
                <padding><Insets top="10" right="16" bottom="10" left="20"/></padding>

                <Label text="Notflix" styleClass="logo"/>

                <TextField fx:id="searchField"
                           promptText="Rechercher..."
                           styleClass="search-field"
                           onAction="#onSearch"
                           prefWidth="240" maxWidth="380"/>
                <Button text="✕" onAction="#onClearSearch" styleClass="btn-icon"/>
                <Button text="Rechercher" onAction="#onSearch" styleClass="btn-s"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- History button -->
                <Button fx:id="historyBtn" text="⏱ Historique"
                        onAction="#onHistory" styleClass="btn-nav"/>

                <!-- Ma Liste -->
                <Button text="♡ Ma Liste" onAction="#onMyList" styleClass="btn-nav"/>

                <!-- Notification bell -->
                <StackPane>
                    <Button fx:id="notifBtn" text="🔔"
                            onAction="#onNotifications" styleClass="btn-icon"/>
                    <Label fx:id="notifBadge" text="0"
                           styleClass="notif-badge"
                           StackPane.alignment="TOP_RIGHT"
                           visible="false" managed="false"/>
                </StackPane>


                <!-- ── THREE-DOT MENU BUTTON ── -->
                <StackPane fx:id="menuAnchor">
                    <Button fx:id="threeDotBtn" text="⋮"
                            styleClass="btn-three-dot"
                            onAction="#onThreeDotMenu"/>
                </StackPane>

            </HBox>
        </top>

        <center>
            <ScrollPane fx:id="mainScroll"
                        fitToWidth="true" fitToHeight="false"
                        styleClass="main-scroll"
                        hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        pannable="false">

                <VBox spacing="0" minWidth="900">

                    <!-- ══ FEATURED BANNER ══ -->
                    <StackPane fx:id="featuredBanner"
                               prefHeight="420"
                               maxWidth="Infinity"
                               styleClass="featured-banner"
                               VBox.vgrow="NEVER">

                        <ImageView fx:id="featuredCover"
                                   preserveRatio="false"
                                   styleClass="featured-cover"
                                   StackPane.alignment="CENTER"/>

                        <Pane styleClass="banner-gradient"
                              mouseTransparent="true"
                              maxWidth="Infinity" maxHeight="Infinity"/>

                        <Button fx:id="bannerPrev" text="&#10094;"
                                onAction="#onBannerPrev"
                                styleClass="banner-nav-btn"
                                StackPane.alignment="CENTER_LEFT">
                            <StackPane.margin><Insets left="18"/></StackPane.margin>
                        </Button>
                        <Button fx:id="bannerNext" text="&#10095;"
                                onAction="#onBannerNext"
                                styleClass="banner-nav-btn"
                                StackPane.alignment="CENTER_RIGHT">
                            <StackPane.margin><Insets right="18"/></StackPane.margin>
                        </Button>

                        <VBox spacing="8"
                              StackPane.alignment="BOTTOM_LEFT"
                              mouseTransparent="false"
                              maxWidth="600">
                            <padding><Insets bottom="24" left="52"/></padding>

                            <Label fx:id="featuredTitle"    styleClass="featured-title"/>
                            <Label fx:id="featuredMeta"     styleClass="featured-meta"/>
                            <Label fx:id="featuredSynopsis" wrapText="true"
                                   styleClass="featured-synopsis" maxWidth="500"/>

                            <HBox fx:id="bannerDots" spacing="6" alignment="CENTER_LEFT">
                                <padding><Insets top="4"/></padding>
                            </HBox>
                        </VBox>

                    </StackPane>

                    <!-- ══ FILTER BAR ══ -->
                    <HBox fx:id="filterBar" spacing="10" alignment="CENTER_LEFT"
                          styleClass="filter-bar">
                        <padding><Insets top="12" right="24" bottom="12" left="24"/></padding>

                        <Label text="Filtrer :" styleClass="filter-label"/>

                        <ComboBox fx:id="filterType"  prefWidth="120" styleClass="combo-dark"
                                  promptText="Type"/>
                        <ComboBox fx:id="filterGenre" prefWidth="150" styleClass="combo-dark"
                                  promptText="Genre"/>
                        <ComboBox fx:id="filterYear"  prefWidth="120" styleClass="combo-dark"
                                  promptText="Année"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="🎲 Surprise"
                                onAction="#onRandomPlay"
                                styleClass="btn-random"/>
                    </HBox>

                    <!-- ══ CATEGORY ROWS ══ -->
                    <VBox fx:id="categoriesContainer" spacing="24"
                          maxWidth="Infinity" VBox.vgrow="ALWAYS">
                        <padding><Insets top="20" right="24" bottom="40" left="24"/></padding>
                    </VBox>

                </VBox>
            </ScrollPane>
        </center>

    </BorderPane>

    <!-- ══ HOVER POPUP LAYER ══ -->
    <Pane fx:id="hoverOverlay"
          mouseTransparent="true" pickOnBounds="false"
          maxWidth="Infinity" maxHeight="Infinity"/>

    <!-- ══ THREE-DOT DROPDOWN POPUP ══ -->
    <VBox fx:id="dropdownMenu"
          styleClass="dropdown-menu"
          visible="false" managed="false"
          pickOnBounds="true"
          StackPane.alignment="TOP_RIGHT">
        <StackPane.margin><Insets top="54" right="12"/></StackPane.margin>

        <!-- User greeting header -->
        <VBox styleClass="dropdown-header" spacing="2">
            <padding><Insets top="14" right="16" bottom="10" left="16"/></padding>
            <Label fx:id="dropdownGreeting" text="Bonjour," styleClass="dropdown-greeting"/>
            <Label fx:id="dropdownUsername" text="User" styleClass="dropdown-username"/>
        </VBox>

        <Pane styleClass="dropdown-divider"/>

        <!-- Go back to dashboard (admin only, shown via code) -->
        <Button fx:id="dropdownDashboard"
                text="🖥  Admin Dashboard"
                styleClass="dropdown-item dropdown-item-admin"
                onAction="#onGoToDashboard"
                maxWidth="Infinity"
                visible="false" managed="false"/>

        <!-- Help -->
        <Button text="❓  Aide &amp; Support"
                styleClass="dropdown-item"
                onAction="#onHelp"
                maxWidth="Infinity"/>

        <Pane styleClass="dropdown-divider"/>

        <!-- Delete account — danger -->
        <Button text="🗑  Supprimer le compte"
                styleClass="dropdown-item dropdown-item-danger"
                onAction="#onDeleteAccount"
                maxWidth="Infinity"/>

        <!-- Logout -->
        <Button text="⏻  Déconnexion"
                styleClass="dropdown-item"
                onAction="#onLogout"
                maxWidth="Infinity"/>

        <Pane prefHeight="6"/>
    </VBox>

</StackPane>
