<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.JavaProject.JavaNetflixProject.app.HomeController"
           stylesheets="@/css/dark-theme.css"
           styleClass="root-pane">

    <!-- ══════════════════ MAIN UI ══════════════════ -->
    <BorderPane>

        <!-- ── TOP BAR ────────────────────────────── -->
        <top>
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="top-bar">
                <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>

                <Label text="Notflix" styleClass="logo"/>

                <TextField fx:id="searchField"
                           promptText="Rechercher..."
                           styleClass="search-field"
                           onAction="#onSearch"
                           prefWidth="280" maxWidth="460"/>
                <Button text="X"           onAction="#onClearSearch" styleClass="btn-icon"/>
                <Button text="Rechercher"  onAction="#onSearch"      styleClass="btn-s"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- History button (#7) -->
                <Button fx:id="historyBtn" text="⏱ Historique"
                        onAction="#onHistory" styleClass="btn-nav"/>

                <!-- Ma Liste -->
                <Button text="♡ Ma Liste" onAction="#onMyList" styleClass="btn-nav"/>

                <!-- Notification bell (#3) -->
                <StackPane>
                    <Button fx:id="notifBtn" text="🔔"
                            onAction="#onNotifications" styleClass="btn-icon"/>
                    <!-- Red badge -->
                    <Label fx:id="notifBadge" text="0"
                           styleClass="notif-badge"
                           StackPane.alignment="TOP_RIGHT"
                           visible="false" managed="false"/>
                </StackPane>

                <Label fx:id="usernameLabel" styleClass="username-label"/>
                <Button text="Déco" onAction="#onLogout" styleClass="btn-logout"/>
            </HBox>
        </top>

        <center>
            <!--
                fx:id="mainScroll" so the controller can forward
                scroll events from card rows to the main scroll.
            -->
            <ScrollPane fx:id="mainScroll"
                        fitToWidth="true" fitToHeight="false"
                        styleClass="main-scroll"
                        hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        pannable="true">

                <VBox spacing="0">

                    <!-- ══ FEATURED BANNER ══ -->
                    <StackPane fx:id="featuredBanner"
                               prefHeight="480"
                               maxWidth="Infinity"
                               styleClass="featured-banner"
                               VBox.vgrow="NEVER">

                        <!-- Cover image — size bound in controller -->
                        <ImageView fx:id="featuredCover"
                                   preserveRatio="false"
                                   styleClass="featured-cover"
                                   StackPane.alignment="CENTER"/>

                        <!-- Gradient scrim -->
                        <Pane styleClass="banner-gradient"
                              mouseTransparent="true"
                              maxWidth="Infinity" maxHeight="Infinity"/>

                        <!-- FIX #4: arrow buttons consume click so banner doesn't open detail -->
                        <Button fx:id="bannerPrev" text="&#10094;"
                                onAction="#onBannerPrev"
                                styleClass="banner-nav-btn"
                                StackPane.alignment="CENTER_LEFT">
                            <StackPane.margin><Insets left="18"/></StackPane.margin>
                        </Button>
                        <Button fx:id="bannerNext" text="&#10095;"
                                onAction="#onBannerNext"
                                styleClass="banner-nav-btn"
                                StackPane.alignment="CENTER_RIGHT">
                            <StackPane.margin><Insets right="18"/></StackPane.margin>
                        </Button>

                        <!--
                            FIX #4: text block + dots together bottom-left.
                            Dots are below the synopsis, NOT in the center of the banner.
                        -->
                        <VBox spacing="10"
                              StackPane.alignment="BOTTOM_LEFT"
                              mouseTransparent="false"
                              maxWidth="660">
                            <padding><Insets bottom="28" left="60"/></padding>

                            <Label fx:id="featuredTitle"    styleClass="featured-title"/>
                            <Label fx:id="featuredMeta"     styleClass="featured-meta"/>
                            <Label fx:id="featuredSynopsis" wrapText="true"
                                   styleClass="featured-synopsis" maxWidth="540"/>

                            <!-- Dots sit just below the synopsis text -->
                            <HBox fx:id="bannerDots" spacing="6" alignment="CENTER_LEFT">
                                <padding><Insets top="6"/></padding>
                            </HBox>
                        </VBox>

                    </StackPane>

                    <!-- ══ FILTER BAR (#2) ══ -->
                    <HBox fx:id="filterBar" spacing="12" alignment="CENTER_LEFT"
                          styleClass="filter-bar">
                        <padding><Insets top="14" right="28" bottom="14" left="28"/></padding>

                        <Label text="Filtrer :" styleClass="filter-label"/>

                        <ComboBox fx:id="filterType"  prefWidth="130" styleClass="combo-dark"
                                  promptText="Type"/>
                        <ComboBox fx:id="filterGenre" prefWidth="160" styleClass="combo-dark"
                                  promptText="Genre"/>
                        <ComboBox fx:id="filterYear"  prefWidth="130" styleClass="combo-dark"
                                  promptText="Année"/>
                    </HBox>

                    <!-- ══ CATEGORY ROWS ══ -->
                    <VBox fx:id="categoriesContainer" spacing="28"
                          maxWidth="Infinity" VBox.vgrow="ALWAYS">
                        <padding><Insets top="20" right="28" bottom="48" left="28"/></padding>
                    </VBox>

                </VBox>
            </ScrollPane>
        </center>

    </BorderPane>

    <!-- ══ HOVER POPUP LAYER — top of StackPane, full-size, above ScrollPane ══ -->
    <Pane fx:id="hoverOverlay"
          mouseTransparent="true" pickOnBounds="false"
          maxWidth="Infinity" maxHeight="Infinity"/>

</StackPane>
