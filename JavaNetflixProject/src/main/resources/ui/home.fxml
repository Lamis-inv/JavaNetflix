<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.JavaProject.JavaNetflixProject.app.HomeController"
           stylesheets="@/css/dark-theme.css"
           styleClass="root-pane">

    <!-- MAIN UI -->
    <BorderPane fx:id="root">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="top-bar">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <Label text="J-Stream" styleClass="logo"/>
             <TextField fx:id="searchField" promptText="🔍 Rechercher..." styleClass="search-field"
                       onAction="#onSearch" prefWidth="300"/>
            <Button text="✕" onAction="#onClearSearch" styleClass="btn-icon"/>
            <Button text="Search" onAction="#onSearch" styleClass="btn-s"/>
            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Ma Liste" onAction="#onMyList" styleClass="btn-nav"/>
            <Label fx:id="usernameLabel" styleClass="username-label"/>
            <Button text="Déconnexion" onAction="#onLogout" styleClass="btn-logout"/>
        </HBox>
    </top>
	
	
    <!-- CENTER CONTENT -->
    <center>
    <ScrollPane fitToWidth="true" styleClass="main-scroll">
    <VBox spacing="20">

        <!-- FEATURED -->
        <VBox spacing="10">
            <Label fx:id="featuredTitle" styleClass="featured-title"/>
            <ImageView fx:id="featuredCover" fitHeight="200" preserveRatio="true"/>
            <Label fx:id="featuredSynopsis" wrapText="true"/>
        </VBox>

        <!-- CATEGORIES -->
        
            <VBox fx:id="categoriesContainer" spacing="20">
			    <padding>
			        <Insets top="20" right="20" bottom="20" left="20"/>
			    </padding>
			</VBox>
        

    </VBox>
    </ScrollPane>
</center>

</BorderPane>

    <!-- NETFLIX HOVER OVERLAY -->
    <Pane fx:id="hoverOverlay" mouseTransparent="true" pickOnBounds="false"/>
</StackPane>
