<?xml version="1.0" encoding="UTF-8"?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.JavaProject.JavaNetflixProject.app.FilmCardController"
           fx:id="cardRoot"
           prefWidth="160"
           prefHeight="240">

    <ImageView fx:id="posterImageView"
               fitWidth="200"
               fitHeight="280"
               preserveRatio="true"/>

    <!-- Dark overlay (hidden by default) -->
    <Region fx:id="darkOverlay"
            visible="false"
            style="-fx-background-color: rgba(0,0,0,0.55);"/>

    <VBox fx:id="infoBox"
          visible="false"
          spacing="4"
          StackPane.alignment="BOTTOM_LEFT"
          styleClass="info-box">
        <Label fx:id="titleLabel" styleClass="movie-title"/>
        <Label fx:id="genreLabel" styleClass="movie-genre"/>
    </VBox>

</StackPane>