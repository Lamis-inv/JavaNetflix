<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.JavaProject.JavaNetflixProject.app.SignUpController"
           styleClass="auth-root"
           stylesheets="@/css/dark-theme.css"
           prefWidth="1100" prefHeight="760">

    <!-- Background -->
    <Region maxWidth="Infinity" maxHeight="Infinity"
            style="-fx-background-color:linear-gradient(to bottom right,#080810 0%,#0c0c18 50%,#080810 100%);"/>
    <Region prefWidth="700" prefHeight="700"
            style="-fx-background-color:radial-gradient(center 75% 25%,radius 50%,rgba(60,40,140,0.07) 0%,transparent 70%);"/>

    <HBox alignment="CENTER" spacing="0" maxHeight="Infinity" maxWidth="Infinity">

        <!-- LEFT: Branding -->
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="24"
              style="-fx-padding:0 60 0 80;">
            <HBox alignment="CENTER_LEFT" spacing="0">
                <Label text="NOT" styleClass="brand-not"/>
                <Label text="FLIX" styleClass="brand-flix"/>
            </HBox>
            <Label text="JOIN THE STREAM" styleClass="brand-tagline"/>
            <Pane prefHeight="10"/>
            <VBox spacing="14">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="▶" style="-fx-text-fill:#444;-fx-font-size:14px;"/>
                    <Label text="Thousands of films &amp; series"
                           style="-fx-text-fill:#1c1c30;-fx-font-size:15px;"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="▶" style="-fx-text-fill:#444;-fx-font-size:14px;"/>
                    <Label text="Continue watching across devices"
                           style="-fx-text-fill:#171728;-fx-font-size:15px;"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="▶" style="-fx-text-fill:#444;-fx-font-size:14px;"/>
                    <Label text="Build your personal watchlist"
                           style="-fx-text-fill:#141422;-fx-font-size:15px;"/>
                </HBox>
            </VBox>

            
        </VBox>

        <!-- RIGHT: Sign up Card -->
        <VBox alignment="CENTER" style="-fx-padding:0 56 0 0;" prefWidth="500" maxWidth="500">
            <ScrollPane fitToWidth="true" styleClass="scroll-pane"
                        style="-fx-background-color:transparent;"
                        prefHeight="660" maxHeight="660">
                <VBox styleClass="auth-card" spacing="0">

                    <!-- Header -->
                    <VBox spacing="6" style="-fx-padding:0 0 22 0;">
                        <Label text="Créer un compte" styleClass="auth-title"/>
                        <Label text="Commencez à regarder en quelques secondes"
                               styleClass="auth-subtitle"/>
                    </VBox>

                    <!-- Name -->
                    <VBox spacing="6" style="-fx-padding:0 0 14 0;">
                        <Label text="NOM D'UTILISATEUR" styleClass="field-label"/>
                        <TextField fx:id="username" styleClass="auth-field"
                                   promptText="ex. Michael Scott" maxWidth="Infinity"/>
                    </VBox>

                    <!-- Email -->
                    <VBox spacing="6" style="-fx-padding:0 0 6 0;">
                        <Label text="ADRESSE EMAIL" styleClass="field-label"/>
                        <TextField fx:id="email" styleClass="auth-field"
                                   promptText="votre@email.com"
                                   maxWidth="Infinity"/>
                    </VBox>

                    

                    <!-- Password -->
                    <VBox spacing="6" style="-fx-padding:0 0 6 0;">
                        <Label text="MOT DE PASSE" styleClass="field-label"/>
                        <PasswordField fx:id="password" styleClass="auth-pass"
                                       promptText="Min 8 caractères, 1 chiffre, 1 symbole"
                                       onKeyReleased="#onPasswordTyped" maxWidth="Infinity"/>
                    </VBox>

                    <!-- Strength bar -->
                    <VBox spacing="5" style="-fx-padding:0 0 14 0;">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <StackPane HBox.hgrow="ALWAYS" styleClass="strength-bar-bg"
                                       alignment="CENTER_LEFT">
                                <Pane fx:id="strengthFill" styleClass="strength-fill-weak"
                                      prefHeight="4" prefWidth="0"/>
                            </StackPane>
                            <Label fx:id="strengthLabel" text=""
                                   styleClass="strength-label" style="-fx-min-width:62px;"/>
                        </HBox>
                        <Label fx:id="passwordHint"
                               text="Utilisez 8+ caractères avec chiffres et symboles."
                               style="-fx-text-fill:#333344;-fx-font-size:10px;"/>
                    </VBox>

                    <!-- Confirm Password -->
                    <VBox spacing="6" style="-fx-padding:0 0 22 0;">
                        <Label text="CONFIRMER LE MOT DE PASSE" styleClass="field-label"/>
                        <PasswordField fx:id="confirmpassword" styleClass="auth-pass"
                                       promptText="••••••••" maxWidth="Infinity"/>
                    </VBox>

                    <!-- Error label -->
                    <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"
                           style="-fx-padding:0 0 12 0;" visible="false" managed="false"/>

                    <!-- Register button -->
                    <Button text="Créer le compte →" styleClass="btn-auth-primary"
                            onAction="#onRegister" maxWidth="Infinity"/>

                    <!-- Divider -->
                    <HBox alignment="CENTER" spacing="12" style="-fx-padding:18 0 18 0;">
                        <Pane styleClass="auth-divider" HBox.hgrow="ALWAYS"/>
                        <Label text="OU"
                               style="-fx-text-fill:#222233;-fx-font-size:10px;-fx-font-weight:700;-fx-letter-spacing:0.2em;"/>
                        <Pane styleClass="auth-divider" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <!-- Login link -->
                    <HBox alignment="CENTER" spacing="6">
                        <Label text="Déjà un compte ?"
                               style="-fx-text-fill:#333344;-fx-font-size:12px;"/>
                        <Hyperlink fx:id="loginLink" text="Se connecter"
                                   styleClass="auth-link-highlight"
                                   onAction="#goToLogin"/>
                    </HBox>

                    <Pane prefHeight="4"/>
                </VBox>
            </ScrollPane>
        </VBox>
    </HBox>
</StackPane>
