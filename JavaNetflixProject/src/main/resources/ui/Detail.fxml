<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.media.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.JavaProject.JavaNetflixProject.app.DetailController"
            styleClass="root-pane"
            stylesheets="@/css/dark-theme.css"
            minWidth="860" minHeight="540">

    <!-- NAVBAR -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="12" bottom="12" left="24" right="24"/></padding>
            <Button text="← Back" onAction="#onBack" styleClass="btn-nav"/>
            <Label text="NOTFLIX" styleClass="brand-nav"/>
            <!-- Now playing label -->
            <Label fx:id="nowPlayingLabel" text="" styleClass="now-playing-label"
                   HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT"/>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="rootStack">

            <ScrollPane fx:id="mainContent" fitToWidth="true" styleClass="main-scroll">
                <VBox spacing="24">
                    <padding><Insets top="24" bottom="40" left="52" right="52"/></padding>

                    <!-- HEADER -->
                    <HBox spacing="28">
                        <ImageView fx:id="coverImage"
                                   fitWidth="190" fitHeight="285"
                                   preserveRatio="true"
                                   style="-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.8),20,0,0,4);-fx-background-radius:8px;"/>

                        <VBox spacing="10" HBox.hgrow="ALWAYS">
                            <Label fx:id="titleLabel" styleClass="detail-title" wrapText="true"/>

                            <HBox spacing="12">
                                <Label fx:id="yearLabel"     styleClass="detail-meta"/>
                                <Label fx:id="durationLabel" styleClass="detail-meta"/>
                                <Label fx:id="categoryLabel" styleClass="badge-film"/>
                                <Label fx:id="ratingLabel"   styleClass="detail-meta"/>
                            </HBox>

                            <Text fx:id="synopsisText" styleClass="detail-synopsis"
                                  wrappingWidth="520" style="-fx-fill:white;"/>

                            <!-- Cast chips -->
                            <Label fx:id="castingLabel" styleClass="detail-casting"
                                   wrapText="true" managed="false" visible="false"/>
                            <FlowPane fx:id="castRow" hgap="6" vgap="6" prefWrapLength="520"/>

                            <!-- Rating -->
                            <VBox spacing="4">
                                <Label text="Your Rating :" styleClass="section-title"
                                       style="-fx-font-size:13px;"/>
                                <HBox fx:id="starsBox" spacing="4"/>
                            </VBox>

                            <!-- Action buttons -->
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Button fx:id="watchlistBtn" text="+ My list"
                                        onAction="#onToggleWatchlist" styleClass="btn-secondary"/>
                                <!-- Bande-annonce — properly styled -->
                                <Button fx:id="trailerBtn" text="▶  Trailer"
                                        onAction="#onPlayTrailer"
                                        styleClass="btn-trailer-fixed"
                                        visible="false" managed="false"/>
                                <!-- Share button -->
                                <Button fx:id="shareBtn" text="↗  Share"
                                        onAction="#onShare"
                                        styleClass="btn-share"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- PLAYER -->
                    <VBox fx:id="filmPlayerBox" spacing="0" styleClass="player-box">

                        <!-- Now Playing info bar -->
                        <HBox fx:id="nowPlayingBar" styleClass="now-playing-bar"
                              alignment="CENTER_LEFT" spacing="12">
                            <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
                            <Label text="▶" style="-fx-text-fill:#e5e5e5;-fx-font-size:12px;"/>
                            <Label fx:id="nowPlayingInfo" text="" styleClass="now-playing-info"
                                   HBox.hgrow="ALWAYS"/>
                            <!-- Keyboard shortcut hints -->
                            <Label text="[Space] Pause  [←] -10s  [→] +10s  [F] Full screen"
                                   styleClass="player-shortcuts"/>
                        </HBox>

                        <StackPane>
                            <MediaView fx:id="mediaView" preserveRatio="true"/>

                            <VBox fx:id="countdownOverlay" alignment="CENTER" spacing="12"
                                  styleClass="countdown-overlay">
                                <Label text="Next Episode" styleClass="countdown-title"/>
                                <Label fx:id="countdownLabel" styleClass="countdown-number"/>
                                <Button text="Cancel" onAction="#onCancelCountdown"
                                        styleClass="btn-secondary"/>
                            </VBox>
                        </StackPane>

                        <!-- Player controls -->
                        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="player-controls">
                            <padding><Insets top="8" bottom="8" left="14" right="14"/></padding>
                            <Button fx:id="playPauseBtn" text="▶" onAction="#onPlayPause"
                                    styleClass="btn-player"/>
                            <!-- -10s -->
                            <Button text="−10" onAction="#onRewind10" styleClass="btn-player-seek"/>
                            <Slider fx:id="progressSlider" HBox.hgrow="ALWAYS"
                                    onMouseReleased="#onSeek" styleClass="progress-slider"/>
                            <!-- +10s -->
                            <Button text="+10" onAction="#onForward10" styleClass="btn-player-seek"/>
                            <Label fx:id="timeLabel" text="00:00 / 00:00" styleClass="time-label"/>
                            <Label text="🔊" styleClass="icon-label"/>
                            <Slider fx:id="volumeSlider" prefWidth="90" styleClass="volume-slider"/>
                            <Button text="⛶" onAction="#onFullscreen" styleClass="btn-player">
							    <tooltip>
							        <Tooltip text="Full screen (F)"/>
							    </tooltip>
							</Button>
                        </HBox>
                    </VBox>

                    <!-- SERIES SECTION -->
                    <VBox fx:id="serieBox" spacing="14">
                        <Label text="Episodes" styleClass="section-title"/>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Season :" styleClass="field-label"/>
                            <ComboBox fx:id="seasonCombo" prefWidth="180" styleClass="combo-dark"/>
                        </HBox>
                        <VBox fx:id="episodeListBox" spacing="8"/>
                    </VBox>

                    <!-- COMMENTS -->
                    <VBox spacing="12">
                        <Label text="💬 Comments" styleClass="section-title"/>
                        <HBox spacing="10">
                            <TextArea fx:id="commentInput" promptText="Share your thoughts..."
                                      prefRowCount="3" HBox.hgrow="ALWAYS" styleClass="text-area-dark"/>
                            <Button text="Post" onAction="#onPostComment" styleClass="btn-primary"/>
                        </HBox>
                        <VBox fx:id="commentsBox" spacing="10"/>
                    </VBox>

                </VBox>
            </ScrollPane>

        </StackPane>
    </center>
</BorderPane>
