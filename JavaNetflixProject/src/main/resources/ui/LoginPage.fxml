<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.JavaProject.JavaNetflixProject.app.LoginController"
           styleClass="auth-root"
           stylesheets="@/css/dark-theme.css"
           prefWidth="1100" prefHeight="700">
           
    <!-- Background gradient panels -->
    <HBox maxWidth="Infinity" maxHeight="Infinity">
        <Region HBox.hgrow="ALWAYS"
                style="-fx-background-color: linear-gradient(to right, #080810 0%, #0c0c18 100%);"/>
    </HBox>

    <!-- Decorative glow blobs -->
    <Region prefWidth="600" prefHeight="600"
            style="-fx-background-color: radial-gradient(center 20% 30%, radius 50%, rgba(232,0,15,0.06) 0%, transparent 70%);"/>
    <Region prefWidth="600" prefHeight="600"
            style="-fx-background-color: radial-gradient(center 80% 70%, radius 40%, rgba(60,40,140,0.08) 0%, transparent 70%);"/>

    <!-- MAIN LAYOUT -->
    <HBox alignment="CENTER" spacing="0" maxHeight="Infinity" maxWidth="Infinity">

        <!-- LEFT: Branding -->
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="28" style="-fx-padding:0 80 0 80;">
            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="0">
                <Label text="NOT" styleClass="brand-not"/>
                <Label text="FLIX" styleClass="brand-flix"/>
            </HBox>
            <Label text="STREAMING PLATFORM" styleClass="brand-tagline"/>
            <Pane prefHeight="16"/>
            <Label text="Watch anything." style="-fx-text-fill:#1a1a2e;-fx-font-size:42px;-fx-font-weight:900;"/>
            <Label text="Anywhere. Anytime." style="-fx-text-fill:#151525;-fx-font-size:38px;-fx-font-weight:900;"/>
            <Label text="Your universe of stories." style="-fx-text-fill:#111120;-fx-font-size:28px;-fx-font-weight:700;"/>
        </VBox>

        <!-- RIGHT: Login Card -->
        <VBox alignment="CENTER" style="-fx-padding: 0 60 0 0;" prefWidth="520" maxWidth="520">
            <VBox styleClass="auth-card" spacing="0">

                <!-- Header -->
                <VBox spacing="6" style="-fx-padding:0 0 28 0;">
                    <Label text="Welcome back" styleClass="auth-title"/>
                    <Label text="Sign in to continue watching" styleClass="auth-subtitle"/>
                </VBox>

                <!-- Email -->
                <VBox styleClass="field-group" spacing="6" style="-fx-padding:0 0 16 0;">
                    <Label text="EMAIL ADDRESS" styleClass="field-label"/>
                    <TextField fx:id="loginEmail" styleClass="auth-field" promptText="your@email.com"
                               onKeyPressed="#onKeyPress" maxWidth="Infinity"/>
                </VBox>

                <!-- Password -->
                <VBox styleClass="field-group" spacing="6" style="-fx-padding:0 0 10 0;">
                    <Label text="PASSWORD" styleClass="field-label"/>
                    <PasswordField fx:id="loginPassword" styleClass="auth-pass" promptText="••••••••"
                                   onKeyPressed="#onKeyPress" maxWidth="Infinity"/>
                </VBox>

                <!-- Forgot password link -->
                <HBox alignment="CENTER_RIGHT" style="-fx-padding:0 0 20 0;">
                    <Hyperlink fx:id="forgotLink" text="Forgot password?" styleClass="auth-link"
                               onAction="#onForgotPassword"/>
                </HBox>

                <!-- Forgot password info box (hidden by default) -->
                <VBox fx:id="forgotBox" styleClass="forgot-box" spacing="6"
                      style="-fx-padding:0 0 18 0;" visible="false" managed="false">
                    <Label text="📬  Verification sent!" styleClass="forgot-title"/>
                    <Label fx:id="maskedEmailLabel" text="" styleClass="forgot-email-masked"/>
                    <Label text="Check your inbox — link expires in 10 minutes." styleClass="forgot-sub"/>
                </VBox>

                <!-- Error label -->
                <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"
                       style="-fx-padding:0 0 14 0;" visible="false" managed="false"/>

                <!-- Login button -->
                <Button text="Sign In →" styleClass="btn-auth-primary"
                        onAction="#onLogin" maxWidth="Infinity"
                        style="-fx-padding:0 0 0 0;"/>

                <!-- Divider -->
                <HBox alignment="CENTER" spacing="12" style="-fx-padding:22 0 22 0;">
                    <Pane styleClass="auth-divider" HBox.hgrow="ALWAYS"/>
                    <Label text="OR" style="-fx-text-fill:#222233;-fx-font-size:10px;-fx-font-weight:700;-fx-letter-spacing:0.2em;"/>
                    <Pane styleClass="auth-divider" HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Sign up link -->
                <HBox alignment="CENTER" spacing="6">
                    <Label text="New to Notflix?" styleClass="auth-link" style="-fx-cursor:default;"/>
                    <Hyperlink fx:id="goToSignUp" text="Create account" styleClass="auth-link-highlight"
                               onAction="#goToSignUp"/>
                </HBox>

            </VBox>
        </VBox>
    </HBox>
</StackPane>
